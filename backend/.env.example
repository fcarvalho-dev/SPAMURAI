# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Anthropic / Groq AI (ANTHROPIC_API_KEY aceita chaves Groq também)
ANTHROPIC_API_KEY=your_api_key

# Encryption - generate with: python -c "import secrets; print(secrets.token_hex(32))"
TOKEN_ENCRYPTION_KEY=your_64_char_hex_key
APP_SECRET_KEY=your_64_char_hex_key

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# App
APP_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Rate Limits
GMAIL_REQUESTS_PER_SECOND=10
MAX_EMAILS_PER_SCAN=5000
