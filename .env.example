# ─── Google OAuth ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Scopes: gmail.modify only — never full https://mail.google.com/
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ─── Anthropic ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Encryption ──────────────────────────────────────────────────
# Generate: openssl rand -hex 32
# 64 hex chars = 32 bytes = 256-bit key for AES-256-GCM
TOKEN_ENCRYPTION_KEY=

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gmail_agent:localdev@localhost:5432/gmail_agent

# ─── Redis / Celery ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── App ─────────────────────────────────────────────────────────
APP_ENV=development  # development | production
APP_SECRET_KEY=      # Generate: openssl rand -hex 32
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ─── Rate Limits ─────────────────────────────────────────────────
# Gmail API: 250 units/user/second, 1B units/day
GMAIL_REQUESTS_PER_SECOND=10
MAX_EMAILS_PER_SCAN=5000
